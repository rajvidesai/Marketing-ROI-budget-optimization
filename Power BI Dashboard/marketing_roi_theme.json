{
  "name": "Rajvi Marketing ROI Theme",
  "dataColors": [
    "#2563EB",
    "#0F766E",
    "#64748B",
    "#EA580C",
    "#16A34A",
    "#1E3A8A",
    "#0F172A",
    "#94A3B8"
  ],
  "background": "#F8FAFC",
  "foreground": "#0F172A",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#334155" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": false,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false,
            "color": { "solid": { "color": "#CBD5E1" } }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F8FAFC" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#0F172A" } },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#475569" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0F172A" } },
            "fontSize": 12
          }
        ]
      }
    }
  }
}
